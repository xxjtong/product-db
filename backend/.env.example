# Product Database — Environment Configuration
# Copy this file to .env and fill in your values.
# 本机测试: cp .env.example .env 然后改 SECRET_KEY 和 API keys 即可运行

# ── Database ──
# SQLite (本地开发推荐)
DATABASE_PATH=/Users/tong/product-db/backend/product_db.db
# PostgreSQL (生产环境)
# DATABASE_URL=postgresql://user:pass@localhost:5432/product_db

# ── Security ──
SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# ── Dev Mode ──
# 本地测试必开: 免登录, 放宽 SECRET_KEY 长度检查
# 生产 systemd 下 DEV_MODE=true 会拒绝启动，除非同时设 FORCE_DEV_MODE=true
DEV_MODE=true

# ── AI (DeepSeek API via local relay) ──
# 本地 relay 代理地址 (one-api / litellm 等)
AI_GATEWAY_URL=http://127.0.0.1:8642
AI_GATEWAY_KEY=sk-your-deepseek-api-key
HERMES_API_URL=http://127.0.0.1:8642
HERMES_API_KEY=

# ── AI Vision (小米 Mimo OCR) ──
VISION_BASE_URL=https://api.xiaomimimo.com/v1
VISION_MODEL=mimo-v2.5
VISION_API_KEY=

# ── Agent ──
# Agent 回调 API 地址 (Hermes 执行工具时调用此地址)
AGENT_API_BASE=http://127.0.0.1:8000

# ── CORS ──
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ── Rate Limiting ──
LOGIN_RATE_LIMIT=10
LOGIN_RATE_WINDOW=300

# ── File Upload ──
IMAGE_MAX_SIZE=5242880
FILE_MAX_SIZE=20971520

# ── AI Tuning ──
AI_MAX_REDIRECTS=3
AI_CONTEXT_CACHE_TTL=300
AI_EXTRACT_MAX_CHARS=12000

# ── Paths ──
FRONTEND_DIST=frontend/dist
WEASYPRINT_PATH=
DISABLE_IP_LOOKUP=false
