# Product Database — Environment Configuration
# Copy this file to .env and fill in your values.

# Database (SQLite default for local dev; PostgreSQL for production)
# DATABASE_URL=postgresql://user:pass@localhost:5432/product_db

# Security
SECRET_KEY=change-me-in-production
# DEV_MODE=true   # only for local development!

# AI (DeepSeek API)
# AI_GATEWAY_KEY=sk-your-deepseek-api-key
